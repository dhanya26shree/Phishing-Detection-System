{
  "manifest_version": 3,
  "name": "Phish Shield AI",
  "version": "1.0",
  "description": "Real-time AI-powered phishing detection for your browser.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:8000/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
